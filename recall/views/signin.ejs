<%- include('partials/signin-head') -%>
<%- include('partials/landing-header') -%>

<div class="min-h-[calc(100vh-72px)] grid grid-cols-1 lg:grid-cols-2">
  <!-- Left: Botski hero (desktop) -->
  <div class="hidden lg:flex flex-col justify-center bg-gradient-to-br from-[#6b089a] via-[#9247c7] to-[#5a0d88] text-white p-12 xl:p-16">
    <div class="mb-12">
      <span class="inline-flex items-center text-white">
        <svg class="inline-block flex-shrink-0" width="157" height="64" viewBox="0 0 157 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect width="64" height="64" rx="14" fill="#7c10bc"/>
          <text x="12" y="48" font-family="Poppins, system-ui, sans-serif" font-size="44" font-weight="800" fill="#FFFFFF">b</text>
          <circle cx="47" cy="14" r="7" fill="#ffb300"/>
          <text x="70" y="46" font-family="Poppins, system-ui, sans-serif" font-size="36" font-weight="700" fill="currentColor">otski</text>
        </svg>
      </span>
      <p class="mt-2 text-xs font-medium text-white/80 uppercase tracking-wider">AI-Powered Meeting Intelligence</p>
    </div>
    <h1 class="text-3xl xl:text-4xl font-bold leading-tight mb-4">Never miss a word</h1>
    <p class="text-white/90 text-lg mb-10 max-w-md">Botski records, transcribes, and summarizes your conversations in real-time.</p>
    <ul class="space-y-4 text-white/90">
      <li class="flex items-center gap-3"><span class="text-[#ffb300]">✓</span> AI-powered meeting transcription</li>
      <li class="flex items-center gap-3"><span class="text-[#ffb300]">✓</span> Automatic summaries & action items</li>
      <li class="flex items-center gap-3"><span class="text-[#ffb300]">✓</span> Works with Zoom, Teams, Google Meet</li>
      <li class="flex items-center gap-3"><span class="text-[#ffb300]">✓</span> Search & organize all your meetings</li>
    </ul>
  </div>

  <!-- Right: Form -->
  <div class="flex flex-col justify-center bg-white p-8 sm:p-12 lg:p-16">
    <div class="w-full max-w-[420px] mx-auto">
      <!-- Logo (mobile + form header) -->
      <div class="mb-10">
        <span class="inline-flex items-center text-[#09070c]">
          <svg class="inline-block flex-shrink-0" width="98" height="40" viewBox="0 0 157 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect width="64" height="64" rx="14" fill="#7c10bc"/>
            <text x="12" y="48" font-family="Poppins, system-ui, sans-serif" font-size="44" font-weight="800" fill="#FFFFFF">b</text>
            <circle cx="47" cy="14" r="7" fill="#ffb300"/>
            <text x="70" y="46" font-family="Poppins, system-ui, sans-serif" font-size="36" font-weight="700" fill="currentColor">otski</text>
          </svg>
        </span>
        <p class="mt-2 text-xs font-medium text-gray-500 uppercase tracking-wider">AI-Powered Meeting Intelligence</p>
      </div>

      <h2 class="text-2xl font-bold text-[#09070c] mb-1">Welcome back</h2>
      <p class="text-gray-600 text-sm mb-8">Sign in to your account to continue</p>

      <div class="form-notice-container mb-6">
        <%- include('partials/notice', { notice: notice }) -%>
      </div>

      <form method="POST" class="space-y-5">
        <div>
          <label for="email" class="block text-sm font-semibold text-gray-700 mb-2">Email address</label>
          <input id="email" name="email" type="email" autocomplete="email" required placeholder="you@example.com"
            class="w-full px-4 py-3 border border-gray-200 rounded-lg text-[#09070c] bg-gray-50/50 focus:bg-white focus:border-[#6b089a] focus:ring-2 focus:ring-[#6b089a]/20 outline-none transition-all">
        </div>
        <div>
          <label for="password" class="block text-sm font-semibold text-gray-700 mb-2">Password</label>
          <input id="password" name="password" type="password" autocomplete="current-password" required placeholder="••••••••"
            class="w-full px-4 py-3 border border-gray-200 rounded-lg text-[#09070c] bg-gray-50/50 focus:bg-white focus:border-[#6b089a] focus:ring-2 focus:ring-[#6b089a]/20 outline-none transition-all">
        </div>
        <button type="submit" class="w-full py-3.5 rounded-lg bg-[#ffb300] text-[#09070c] font-semibold shadow-lg hover:opacity-95 transition-opacity">
          Sign in
        </button>
      </form>

      <div class="flex items-center gap-4 my-8">
        <div class="flex-1 h-px bg-gray-200"></div>
        <span class="text-xs font-medium text-gray-400">OR</span>
        <div class="flex-1 h-px bg-gray-200"></div>
      </div>

      <div class="flex flex-col gap-3">
        <% if (typeof googleSignInUrl !== 'undefined' && googleSignInUrl) { %>
        <a href="<%= googleSignInUrl %>" class="flex items-center justify-center gap-3 py-3 px-4 border border-gray-200 rounded-lg bg-white font-semibold text-gray-700 hover:bg-gray-50 transition-colors no-underline">
          <svg width="18" height="18" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
          Continue with Google
        </a>
        <% } else { %>
        <button type="button" disabled class="flex items-center justify-center gap-3 py-3 px-4 border border-gray-200 rounded-lg bg-gray-50 font-semibold text-gray-400 cursor-not-allowed">
          Continue with Google (not configured)
        </button>
        <% } %>
        <% if (typeof microsoftSignInUrl !== 'undefined' && microsoftSignInUrl) { %>
        <a href="<%= microsoftSignInUrl %>" class="flex items-center justify-center gap-3 py-3 px-4 border border-gray-200 rounded-lg bg-white font-semibold text-gray-700 hover:bg-gray-50 transition-colors no-underline">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M11.4 24v-11.85H8.1V8.65h3.3V6.1c0-3.27 2-5.05 4.9-5.05 1.4 0 2.6.1 2.95.15v3.42h-2.02c-1.6 0-1.9.76-1.9 1.87v2.45h3.8l-.5 3.5h-3.3V24"/></svg>
          Continue with Microsoft
        </a>
        <% } else { %>
        <button type="button" disabled class="flex items-center justify-center gap-3 py-3 px-4 border border-gray-200 rounded-lg bg-gray-50 font-semibold text-gray-400 cursor-not-allowed">
          Continue with Microsoft (not configured)
        </button>
        <% } %>
      </div>

      <p class="mt-8 text-center text-sm text-gray-600">
        Don't have an account?
        <a href="/sign-up" class="font-semibold text-[#6b089a] hover:underline">Sign up for free</a>
      </p>
    </div>
  </div>
</div>

</body>
</html>
