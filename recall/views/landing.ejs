<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Botski AI – Turn every conversation into outcomes</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { sans: ['Poppins', 'system-ui', 'sans-serif'] },
          colors: {
            botski: {
              amber: '#ffb300',
              dark: '#09070c',
              purple: '#6b089a',
              purpleLight: '#9247c7',
              darkBlue: '#0a1f3d',
              midBlue: '#1a5fa8',
              blue: '#8ad5fc',
            }
          }
        }
      }
    }
  </script>
  <style>
    html { font-family: 'Poppins', system-ui, sans-serif; }
    section { scroll-margin-top: 88px; }
  </style>
</head>
<body class="font-sans antialiased text-[#09070c]">
  <%- include('partials/landing-header') -%>

  <main>
    <!-- Hero -->
    <section class="bg-gradient-to-br from-[#6b089a] via-[#7c1aa8] to-[#6b089a] text-white pt-[100px] pb-20 px-6 sm:px-10 lg:pt-[100px] lg:pb-20 lg:px-[120px]">
      <div class="mx-auto max-w-7xl">
        <span class="inline-block rounded-full bg-white/20 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider">AI Meeting Assistant</span>
        <h1 class="mt-6 text-4xl font-bold leading-tight sm:text-5xl lg:text-[72px] lg:leading-[1.1]">Turn every conversation into outcomes.</h1>
        <p class="mt-6 max-w-xl text-lg text-white/90">Botski joins your meetings, captures what matters, and delivers transcripts, summaries, and action items—so you can focus on the conversation.</p>
        <div class="mt-10 flex flex-wrap gap-4">
          <a href="/sign-up" class="inline-flex items-center justify-center rounded-lg bg-[#ffb300] px-6 py-3.5 text-base font-semibold text-[#09070c] shadow-lg hover:opacity-95 transition-opacity">Start Free</a>
          <a href="#demo" class="inline-flex items-center justify-center rounded-lg border-2 border-white/80 bg-transparent px-6 py-3.5 text-base font-semibold text-white hover:bg-white/10 transition-colors">Watch Demo</a>
        </div>
        <p class="mt-10 text-sm text-white/80">Works with Zoom, Google Meet, Microsoft Teams</p>
        <div class="mt-12 flex items-center gap-8 text-white/60 text-sm">
          <span>Zoom</span>
          <span>Google Meet</span>
          <span>Microsoft Teams</span>
        </div>
      </div>
    </section>

    <!-- Problem: Before / After -->
    <section id="problem" class="bg-white py-16 px-6 sm:px-10 lg:py-24 lg:px-[120px]">
      <div class="mx-auto max-w-7xl">
        <h2 class="text-3xl font-bold sm:text-4xl lg:text-[52px] lg:leading-tight">Meetings create work. Botski removes it.</h2>
        <div class="mt-12 grid gap-8 md:grid-cols-2">
          <div class="rounded-2xl border border-gray-200 bg-gray-50/50 p-8">
            <p class="text-sm font-semibold uppercase tracking-wider text-gray-500">Before</p>
            <h3 class="mt-2 text-xl font-semibold">Every meeting ends with more to-do</h3>
            <p class="mt-4 text-gray-600">Notes scattered, action items lost, follow-ups forgotten.</p>
          </div>
          <div class="rounded-2xl border border-gray-200 bg-gray-50/50 p-8">
            <p class="text-sm font-semibold uppercase tracking-wider text-gray-500">After</p>
            <h3 class="mt-2 text-xl font-semibold">Meeting ends, everything is done</h3>
            <p class="mt-4 text-gray-600">Transcripts, summaries, and action items—automatically.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section id="how-it-works" class="bg-gradient-to-br from-[#0a1f3d] to-[#1a5fa8] text-white py-16 px-6 sm:px-10 lg:py-24 lg:px-[120px]">
      <div class="mx-auto max-w-7xl">
        <p class="text-sm font-semibold uppercase tracking-wider text-white/80">How It Works</p>
        <h2 class="mt-2 text-3xl font-bold sm:text-4xl lg:text-[48px]">Three simple steps.</h2>
        <div class="mt-14 grid gap-8 md:grid-cols-3">
          <div class="rounded-xl border border-white/20 bg-white/10 p-8 backdrop-blur-sm">
            <span class="text-2xl font-bold text-[#ffb300]">01</span>
            <h3 class="mt-4 text-xl font-semibold">Connect your calendar</h3>
            <p class="mt-3 text-white/90">Link Google Calendar or Outlook. Botski sees your meetings.</p>
          </div>
          <div class="rounded-xl border border-white/20 bg-white/10 p-8 backdrop-blur-sm">
            <span class="text-2xl font-bold text-[#ffb300]">02</span>
            <h3 class="mt-4 text-xl font-semibold">Botski joins</h3>
            <p class="mt-3 text-white/90">Our bot joins Zoom, Meet, or Teams and captures the conversation.</p>
          </div>
          <div class="rounded-xl border border-white/20 bg-white/10 p-8 backdrop-blur-sm">
            <span class="text-2xl font-bold text-[#ffb300]">03</span>
            <h3 class="mt-4 text-xl font-semibold">Get outputs</h3>
            <p class="mt-3 text-white/90">Transcript, summary, and action items—ready to use or share.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section id="features" class="bg-[#f8f6fc] py-16 px-6 sm:px-10 lg:py-24 lg:px-[120px]">
      <div class="mx-auto max-w-7xl">
        <p class="text-sm font-semibold uppercase tracking-wider text-gray-600">Features</p>
        <h2 class="mt-2 text-3xl font-bold sm:text-4xl lg:text-[48px]">Everything you need after the meeting.</h2>
        <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          <div class="rounded-[18px] bg-white p-8 shadow-sm">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-purple-100 text-[#6b089a]">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" x2="12" y1="19" y2="22"/></svg>
            </div>
            <h3 class="mt-5 text-lg font-semibold">Meeting transcription</h3>
            <div class="my-4 border-t border-gray-100"></div>
            <p class="text-gray-600">Full, searchable transcripts for every meeting. Never miss a detail.</p>
          </div>
          <div class="rounded-[18px] bg-white p-8 shadow-sm">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-purple-100 text-[#6b089a]">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" x2="8" y1="13" y2="13"/><line x1="16" x2="8" y1="17" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
            </div>
            <h3 class="mt-5 text-lg font-semibold">Smart summaries</h3>
            <div class="my-4 border-t border-gray-100"></div>
            <p class="text-gray-600">AI-generated summaries so you can skim in seconds.</p>
          </div>
          <div class="rounded-[18px] bg-white p-8 shadow-sm">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-purple-100 text-[#6b089a]">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
            </div>
            <h3 class="mt-5 text-lg font-semibold">Action items</h3>
            <div class="my-4 border-t border-gray-100"></div>
            <p class="text-gray-600">Clear next steps extracted and ready to assign or track.</p>
          </div>
          <div class="rounded-[18px] bg-white p-8 shadow-sm">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-purple-100 text-[#6b089a]">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><path d="M2 10h20"/></svg>
            </div>
            <h3 class="mt-5 text-lg font-semibold">Email drafts</h3>
            <div class="my-4 border-t border-gray-100"></div>
            <p class="text-gray-600">Follow-up emails drafted from the meeting—edit and send.</p>
          </div>
          <div class="rounded-[18px] bg-white p-8 shadow-sm">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-purple-100 text-[#6b089a]">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            </div>
            <h3 class="mt-5 text-lg font-semibold">Integrations</h3>
            <div class="my-4 border-t border-gray-100"></div>
            <p class="text-gray-600">Send to Notion, Slack, and your favorite tools.</p>
          </div>
          <div class="rounded-[18px] bg-white p-8 shadow-sm">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-purple-100 text-[#6b089a]">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            </div>
            <h3 class="mt-5 text-lg font-semibold">Search & ask</h3>
            <div class="my-4 border-t border-gray-100"></div>
            <p class="text-gray-600">Search across meetings or ask the AI anything about your calls.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Audience / Who It's For -->
    <section id="audience" class="bg-gradient-to-br from-[#0a1f3d] to-[#1a5fa8] text-white py-16 px-6 sm:px-10 lg:py-24 lg:px-[120px]">
      <div class="mx-auto max-w-7xl">
        <p class="text-sm font-semibold uppercase tracking-wider text-white/80">Who It's For</p>
        <h2 class="mt-2 text-3xl font-bold sm:text-4xl lg:text-[48px]">Built for people who sell their time.</h2>
        <div class="mt-14 rounded-2xl border border-white/20 bg-white/10 overflow-hidden backdrop-blur-sm" style="min-height: 420px;">
          <div class="grid md:grid-cols-2">
            <div class="flex items-center justify-center bg-white/5 p-10">
              <div class="h-64 w-full max-w-md rounded-lg bg-white/10 flex items-center justify-center text-white/60 text-sm">Meeting / call illustration</div>
            </div>
            <div class="flex flex-col justify-center p-10">
              <p class="text-white/90">Consultants, coaches, and anyone who runs client calls. Get a full record and deliverables without lifting a finger.</p>
            </div>
          </div>
        </div>
        <div class="mt-8 flex justify-center gap-2" aria-label="Slide navigation">
          <button type="button" class="h-2.5 w-2.5 rounded-full bg-[#ffb300]" aria-current="true"></button>
          <button type="button" class="h-2.5 w-2.5 rounded-full bg-white/40 hover:bg-white/60"></button>
          <button type="button" class="h-2.5 w-2.5 rounded-full bg-white/40 hover:bg-white/60"></button>
          <button type="button" class="h-2.5 w-2.5 rounded-full bg-white/40 hover:bg-white/60"></button>
          <button type="button" class="h-2.5 w-2.5 rounded-full bg-white/40 hover:bg-white/60"></button>
        </div>
      </div>
    </section>

    <!-- Differentiation: Why Botski -->
    <section class="bg-white py-16 px-6 sm:px-10 lg:py-24 lg:px-[120px]">
      <div class="mx-auto max-w-7xl">
        <p class="text-sm font-semibold uppercase tracking-wider text-gray-600">Why Botski</p>
        <h2 class="mt-2 text-3xl font-bold sm:text-4xl lg:text-[48px]">Not another meeting recorder.</h2>
        <p class="mt-4 max-w-2xl text-gray-600">We focus on outcomes: summaries, action items, and follow-ups—so you close the loop instead of piling up notes.</p>
        <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          <div class="rounded-[14px] bg-[#faf8ff] p-6">
            <h3 class="font-semibold">Outcome-first</h3>
            <p class="mt-2 text-sm text-gray-600">Built for what happens after the call.</p>
          </div>
          <div class="rounded-[14px] bg-[#faf8ff] p-6">
            <h3 class="font-semibold">Privacy & compliance</h3>
            <p class="mt-2 text-sm text-gray-600">European hosting, GDPR compliant.</p>
          </div>
          <div class="rounded-[14px] bg-[#faf8ff] p-6">
            <h3 class="font-semibold">One bot, all tools</h3>
            <p class="mt-2 text-sm text-gray-600">Transcript, summary, actions in one place.</p>
          </div>
          <div class="rounded-[14px] bg-[#faf8ff] p-6">
            <h3 class="font-semibold">Your data stays yours</h3>
            <p class="mt-2 text-sm text-gray-600">Export and control your content.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Example output -->
    <section class="bg-gradient-to-br from-[#0a1f3d] to-[#1a5fa8] text-white py-16 px-6 sm:px-10 lg:py-24 lg:px-[120px]">
      <div class="mx-auto max-w-7xl">
        <p class="text-sm font-semibold uppercase tracking-wider text-white/80">See It In Action</p>
        <h2 class="mt-2 text-3xl font-bold sm:text-4xl lg:text-[48px]">What Botski produces after your meeting.</h2>
        <div class="mt-14 grid gap-6 md:grid-cols-3">
          <div class="rounded-xl border border-white/20 bg-white/10 p-6 backdrop-blur-sm">
            <h3 class="font-semibold">Transcript</h3>
            <p class="mt-2 text-sm text-white/90">Full, timestamped transcript ready to search or share.</p>
          </div>
          <div class="rounded-xl border border-white/20 bg-white/10 p-6 backdrop-blur-sm">
            <h3 class="font-semibold">Summary</h3>
            <p class="mt-2 text-sm text-white/90">Concise overview with key points and decisions.</p>
          </div>
          <div class="rounded-xl border border-white/20 bg-white/10 p-6 backdrop-blur-sm">
            <h3 class="font-semibold">Action items</h3>
            <p class="mt-2 text-sm text-white/90">Clear next steps with owners and due dates.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing -->
    <section id="pricing" class="bg-white py-16 px-6 sm:px-10 lg:py-24 lg:px-[120px]">
      <div class="mx-auto max-w-7xl">
        <p class="text-sm font-semibold uppercase tracking-wider text-gray-600">Pricing</p>
        <h2 class="mt-2 text-3xl font-bold sm:text-4xl lg:text-[48px]">Simple, honest pricing.</h2>
        <div class="mt-14 flex flex-wrap justify-center gap-8">
          <div class="w-full max-w-[380px] rounded-2xl border border-gray-200 bg-[#faf8ff] p-10">
            <h3 class="text-xl font-semibold">Starter</h3>
            <p class="mt-4 text-3xl font-bold">Free</p>
            <p class="mt-2 text-gray-600">Get started with core features.</p>
            <a href="/sign-up" class="mt-8 inline-block w-full rounded-lg border-2 border-[#6b089a] bg-transparent py-3 text-center font-semibold text-[#6b089a] hover:bg-[#6b089a] hover:text-white transition-colors">Start Free</a>
          </div>
          <div class="w-full max-w-[380px] rounded-2xl border-2 border-[#6b089a] bg-[#6b089a] p-10 text-white shadow-xl">
            <h3 class="text-xl font-semibold">Pro</h3>
            <p class="mt-4 text-3xl font-bold">Coming soon</p>
            <p class="mt-2 text-white/90">More meetings, more outputs, more power.</p>
            <a href="#demo" class="mt-8 inline-block w-full rounded-lg bg-[#ffb300] py-3 text-center font-semibold text-[#09070c] hover:opacity-95 transition-opacity">Book a Demo</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="bg-gradient-to-br from-[#6b089a] via-[#7c1aa8] to-[#6b089a] text-white py-24 px-6 sm:px-10 lg:py-[120px] lg:px-[120px]">
      <div class="mx-auto max-w-4xl text-center">
        <h2 class="text-3xl font-bold sm:text-4xl lg:text-[48px]">Stop writing meeting notes. Start closing work.</h2>
        <div class="mt-10 flex flex-wrap justify-center gap-4">
          <a href="/sign-up" class="inline-flex items-center justify-center rounded-lg bg-[#ffb300] px-8 py-4 text-base font-semibold text-[#09070c] shadow-lg hover:opacity-95 transition-opacity">Start Free</a>
          <a href="#demo" class="inline-flex items-center justify-center rounded-lg border-2 border-white/80 bg-transparent px-8 py-4 text-base font-semibold text-white hover:bg-white/10 transition-colors">Book a Demo</a>
        </div>
        <p class="mt-10 text-sm text-white/80">No credit card required • GDPR compliant • Cancel anytime</p>
      </div>
    </section>
  </main>

  <%- include('partials/landing-footer') -%>
</body>
</html>
