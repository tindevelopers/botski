<%# Botski logo — Logo Refined concept D: mark (rounded rect + white "b" + amber dot) + "otski". Pass size ('sm'|'md'|'lg'), wordLight (true for white "otski" on dark). %>
<%
  const logoSize = typeof size !== 'undefined' ? size : 'md';
  const logoWordLight = typeof wordLight !== 'undefined' ? wordLight : false;
  const sizes = { sm: 0.375, md: 0.625, lg: 1 };
  const scale = sizes[logoSize] || sizes.md;
  const w = Math.round(157 * scale);
  const h = logoSize === 'sm' ? 24 : (logoSize === 'lg' ? 64 : 40);
%>
<span class="inline-flex items-center <%= logoWordLight ? 'text-white' : 'text-[#09070c]' %> <%= typeof className !== 'undefined' ? className : '' %>">
  <svg class="inline-block flex-shrink-0" width="<%= w %>" height="<%= h %>" viewBox="0 0 157 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <rect width="64" height="64" rx="14" fill="#7c10bc"/>
    <text x="12" y="48" font-family="Poppins, system-ui, sans-serif" font-size="44" font-weight="800" fill="#FFFFFF">b</text>
    <circle cx="47" cy="14" r="7" fill="#ffb300"/>
    <text x="70" y="46" font-family="Poppins, system-ui, sans-serif" font-size="36" font-weight="700" fill="currentColor">otski</text>
  </svg>
</span>
