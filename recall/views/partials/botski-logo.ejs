<%# Botski logo — Concept D. Pass size ('sm'|'md'|'lg'). %>
<%
  const logoSize = typeof size !== 'undefined' ? size : 'md';
  const heights = { sm: 24, md: 36, lg: 52 };
  const h = heights[logoSize] || heights.md;
%>
<img src="/images/botski-logo.png" alt="Botski" height="<%= h %>" class="inline-block" style="height:<%= h %>px;width:auto;">
