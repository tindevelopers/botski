<%-
  var artifactId = meeting && meeting.artifactId;
  var prefix = typeof closeDrawerPrefix !== 'undefined' ? closeDrawerPrefix : '';
  var targets = (typeof enabledPublishTargets !== 'undefined' && Array.isArray(enabledPublishTargets) && enabledPublishTargets.length)
    ? enabledPublishTargets
    : [{ type: 'notion' }, { type: 'slack' }];
  var btnBase = typeof buttonClass !== 'undefined' ? buttonClass : 'w-full inline-flex items-center justify-center rounded-md bg-white px-3 py-2 text-sm font-semibold ring-1 ring-inset hover:bg-gray-50';
  var allLabel = typeof allDestinationsLabel !== 'undefined' ? allDestinationsLabel : 'Publish to All Destinations';
-%>
<% if (artifactId) { %>
  <% targets.forEach(function(t) { %>
    <% if (t.type === 'notion') { %>
  <button type="button" onclick="<%= prefix %>openNotionDestinationPicker('<%= artifactId %>')" class="<%= btnBase %> text-indigo-600 ring-indigo-200 hover:bg-indigo-50">
    Publish to Notion
  </button>
    <% } else if (t.type === 'slack') { %>
  <button type="button" onclick="<%= prefix %>openSlackDestinationPicker('<%= artifactId %>')" class="<%= btnBase %> text-sky-600 ring-sky-200 hover:bg-sky-50">
    Publish to Slack
  </button>
    <% } else { %>
  <button type="button" onclick="<%= prefix %>publishToNotion('<%= artifactId %>', this)" class="<%= btnBase %> <%= t.type === 'teamwork' ? 'text-emerald-700 ring-emerald-200 hover:bg-emerald-50' : 'text-gray-700 ring-gray-300 hover:bg-gray-50' %>">
    <span data-publish-text>Publish to <%= t.type === 'teamwork' ? 'Teamwork' : (t.type.charAt(0).toUpperCase() + (t.type.slice(1) || '')) %></span>
  </button>
    <% } %>
  <% }); %>
  <button type="button" onclick="<%= prefix %>publishToNotion('<%= artifactId %>', this)" class="<%= btnBase %> text-gray-700 ring-gray-300 hover:bg-gray-50">
    <span data-publish-text><%= allLabel %></span>
  </button>
<% } else { %>
  <p class="text-xs text-gray-500">Publishing is available once the recording is processed.</p>
<% } %>
