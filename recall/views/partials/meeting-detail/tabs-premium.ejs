<div class="overflow-hidden bg-white shadow sm:rounded-lg w-full">
  <div class="border-b border-gray-200">
    <div class="sm:hidden px-4 py-3">
      <label class="sr-only" for="tab-select">Select a tab</label>
      <select
        id="tab-select"
        class="block w-full rounded-md border-gray-300 py-2 pl-3 pr-10 text-sm focus:border-indigo-500 focus:outline-none focus:ring-indigo-500"
        onchange="switchTab(this.value)"
      >
        <option value="summary" selected>Summary</option>
        <option value="chapters">Chapters</option>
        <option value="highlights">Highlights</option>
        <option value="actions">Actions</option>
        <option value="transcript">Transcript</option>
        <option value="stats">Stats</option>
        <option value="media">Media</option>
        <option value="quickactions">Quick Actions</option>
      </select>
    </div>
    <div class="hidden sm:block w-full">
      <div class="flex flex-wrap items-center gap-3 px-4 py-3 border-b border-gray-100">
        <span class="inline-flex items-center rounded-full border border-amber-500 bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-700">
          Premium
        </span>
        <span class="inline-flex items-center rounded-full bg-amber-50 px-2 py-0.5 text-xs font-medium text-amber-700 ring-1 ring-inset ring-amber-200">
          Source: Super Agent
        </span>
        <span class="text-xs text-gray-500">Powered by Super Agent</span>
      </div>
      <!-- Premium Tabs Navigation (pt-2 gives room so notification badges are not clipped) -->
      <div class="w-full overflow-x-auto overflow-y-visible scrollbar-hide pt-2">
      <nav class="-mb-px flex w-full flex-wrap sm:flex-nowrap" aria-label="Premium Tabs" role="tablist">
        <button
          type="button"
          onclick="switchTab('summary')"
          id="tab-summary"
          role="tab"
          aria-controls="content-summary"
          aria-selected="true"
          tabindex="0"
          class="tab-btn group relative flex-1 min-w-0 border-indigo-500 text-indigo-600 whitespace-nowrap border-b-2 py-3 px-2 sm:px-3 text-center text-xs sm:text-sm font-medium transition-colors"
        >
          <svg class="mx-auto h-4 w-4 sm:h-5 sm:w-5 mb-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
          </svg>
          Summary
        </button>
        <button
          type="button"
          onclick="switchTab('chapters')"
          id="tab-chapters"
          role="tab"
          aria-controls="content-chapters"
          aria-selected="false"
          tabindex="-1"
          class="tab-btn group relative flex-1 min-w-0 border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 whitespace-nowrap border-b-2 py-3 px-2 sm:px-3 text-center text-xs sm:text-sm font-medium transition-colors"
        >
          <svg class="mx-auto h-4 w-4 sm:h-5 sm:w-5 mb-0.5 group-hover:text-indigo-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h10"></path>
          </svg>
          Chapters
        </button>
        <button
          type="button"
          onclick="switchTab('highlights')"
          id="tab-highlights"
          role="tab"
          aria-controls="content-highlights"
          aria-selected="false"
          tabindex="-1"
          class="tab-btn group relative flex-1 min-w-0 border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 whitespace-nowrap border-b-2 py-3 px-2 sm:px-3 text-center text-xs sm:text-sm font-medium transition-colors"
        >
          <svg class="mx-auto h-5 w-5 mb-0.5 group-hover:text-indigo-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
          Highlights
        </button>
        <button
          type="button"
          onclick="switchTab('actions')"
          id="tab-actions"
          role="tab"
          aria-controls="content-actions"
          aria-selected="false"
          tabindex="-1"
          class="tab-btn group relative flex-1 min-w-0 border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 whitespace-nowrap border-b-2 py-3 px-2 sm:px-3 text-center text-xs sm:text-sm font-medium transition-colors"
        >
          <svg class="mx-auto h-5 w-5 mb-0.5 group-hover:text-indigo-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path>
          </svg>
          Actions
          <% if (meeting.superAgentAnalysis?.actionItems && meeting.superAgentAnalysis.actionItems.length > 0) { %>
            <span class="absolute -top-1 -right-1 inline-flex items-center justify-center h-5 w-5 rounded-full bg-amber-500 text-xs font-bold text-white"><%= meeting.superAgentAnalysis.actionItems.length %></span>
          <% } %>
        </button>
        <button
          type="button"
          onclick="switchTab('transcript')"
          id="tab-transcript"
          role="tab"
          aria-controls="content-transcript"
          aria-selected="false"
          tabindex="-1"
          class="tab-btn group relative flex-1 min-w-0 border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 whitespace-nowrap border-b-2 py-3 px-2 sm:px-3 text-center text-xs sm:text-sm font-medium transition-colors"
        >
          <svg class="mx-auto h-5 w-5 mb-0.5 group-hover:text-indigo-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
          </svg>
          Transcript
        </button>
        <button
          type="button"
          onclick="switchTab('stats')"
          id="tab-stats"
          role="tab"
          aria-controls="content-stats"
          aria-selected="false"
          tabindex="-1"
          class="tab-btn group relative flex-1 min-w-0 border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 whitespace-nowrap border-b-2 py-3 px-2 sm:px-3 text-center text-xs sm:text-sm font-medium transition-colors"
        >
          <svg class="mx-auto h-4 w-4 sm:h-5 sm:w-5 mb-0.5 group-hover:text-indigo-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"></path>
          </svg>
          Stats
        </button>
        <button
          type="button"
          onclick="switchTab('media')"
          id="tab-media"
          role="tab"
          aria-controls="content-media"
          aria-selected="false"
          tabindex="-1"
          class="tab-btn group relative flex-1 min-w-0 border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 whitespace-nowrap border-b-2 py-3 px-2 sm:px-3 text-center text-xs sm:text-sm font-medium transition-colors"
        >
          <svg class="mx-auto h-4 w-4 sm:h-5 sm:w-5 mb-0.5 group-hover:text-indigo-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
          </svg>
          Media
        </button>
        <button
          type="button"
          onclick="switchTab('quickactions')"
          id="tab-quickactions"
          role="tab"
          aria-controls="content-quickactions"
          aria-selected="false"
          tabindex="-1"
          class="tab-btn group relative flex-1 min-w-0 border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 whitespace-nowrap border-b-2 py-3 px-2 sm:px-3 text-center text-xs sm:text-sm font-medium transition-colors"
        >
          <svg class="mx-auto h-4 w-4 sm:h-5 sm:w-5 mb-0.5 group-hover:text-indigo-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
          Actions
        </button>
      </nav>
      </div>
    </div>
  </div>

  <div class="px-4 py-5 sm:px-6">
    <!-- Summary Tab -->
    <div id="content-summary" class="tab-content" role="tabpanel" aria-labelledby="tab-summary">
      <%- include('tab-premium', { meeting, publishDeliveries }) -%>
    </div>

    <!-- Chapters Tab (replaces Topics) -->
    <div id="content-chapters" class="tab-content hidden" role="tabpanel" aria-labelledby="tab-chapters">
      <% if (!meeting.superAgentAnalysis || meeting.superAgentAnalysis.status !== 'completed') { %>
        <div class="text-center py-8">
          <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6l4 2m6-2a10 10 0 11-20 0 10 10 0 0120 0z"></path>
          </svg>
          <h3 class="mt-2 text-sm font-semibold text-gray-900">Chapters not ready</h3>
          <p class="mt-1 text-sm text-gray-500">Run Super Agent to generate chapters.</p>
          <% if (meeting.artifactId) { %>
            <button
              type="button"
              onclick="openSuperAgentPanel()"
              class="mt-4 inline-flex items-center rounded-md bg-amber-500 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-amber-400"
            >
              Analyse with Super Agent
            </button>
          <% } %>
        </div>
      <% } else { %>
        <% const chapters = meeting.superAgentAnalysis?.chapters || []; %>
        <% if (chapters.length > 0) { %>
          <div class="flex items-center justify-between mb-4">
            <div>
              <h3 class="text-base font-semibold text-gray-900">Chapters</h3>
              <p class="text-sm text-gray-500">Chapters with timestamps.</p>
            </div>
          </div>
          <div class="divide-y divide-gray-200 border border-gray-200 rounded-lg">
            <% chapters.forEach((chapter, idx) => {
              const start = typeof chapter.start === 'number' ? Math.floor(chapter.start / 1000) : null;
              const end = typeof chapter.end === 'number' ? Math.floor(chapter.end / 1000) : null;
              const title = chapter.headline || chapter.gist || `Chapter ${idx + 1}`;
            %>
              <div class="px-4 py-3">
                <div class="flex items-center justify-between">
                  <p class="text-sm font-semibold text-gray-900"><%= title %></p>
                  <% if (start !== null) { %>
                    <button
                      type="button"
                      class="inline-flex items-center rounded-full bg-indigo-50 px-2 py-0.5 text-xs text-indigo-700 ring-1 ring-indigo-200 hover:bg-indigo-100"
                      onclick="jumpToTimestamp(<%= start %>)"
                    >
                      <svg class="h-3 w-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                      </svg>
                      <%= Math.floor(start / 60) %>:<%= String(Math.floor(start % 60)).padStart(2, '0') %><%= end !== null ? `-${Math.floor(end / 60)}:${String(Math.floor(end % 60)).padStart(2, '0')}` : '' %>
                    </button>
                  <% } %>
                </div>
                <% if (chapter.summary) { %>
                  <p class="mt-2 text-sm text-gray-700"><%= chapter.summary %></p>
                <% } %>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <div class="text-center py-8">
            <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 00-2 2h-5l-4 4v-4z"></path>
            </svg>
            <h3 class="mt-2 text-sm font-semibold text-gray-900">No chapters available</h3>
            <p class="mt-1 text-sm text-gray-500">No chapters available for this meeting.</p>
          </div>
        <% } %>
      <% } %>
    </div>

    <!-- Highlights Tab -->
    <div id="content-highlights" class="tab-content hidden" role="tabpanel" aria-labelledby="tab-highlights">
      <% if (!meeting.superAgentAnalysis || meeting.superAgentAnalysis.status !== 'completed') { %>
        <div class="text-center py-8">
          <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
          <h3 class="mt-2 text-sm font-semibold text-gray-900">Premium highlights not ready</h3>
          <p class="mt-1 text-sm text-gray-500">Run Super Agent to generate highlights.</p>
          <% if (meeting.artifactId) { %>
            <button
              type="button"
              onclick="openSuperAgentPanel()"
              class="mt-4 inline-flex items-center rounded-md bg-amber-500 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-amber-400"
            >
              Analyse with Super Agent
            </button>
          <% } %>
        </div>
      <% } else { %>
        <% const premiumHighlights = meeting.superAgentAnalysis?.highlights || []; %>
        <% if (premiumHighlights.length > 0) { %>
          <ul class="space-y-3">
            <% premiumHighlights.forEach(function(item, idx) { %>
              <li class="p-3 rounded-lg border border-gray-100 bg-gray-50">
                <div class="flex items-start justify-between">
                  <div>
                    <p class="text-sm font-semibold text-gray-900"><%= item.title || 'Highlight ' + (idx + 1) %></p>
                    <p class="mt-1 text-sm text-gray-700"><%= item.content || item.summary || item.text || '' %></p>
                    <div class="mt-2 flex flex-wrap gap-2 text-xs text-gray-500">
                      <% if (item.speaker) { %>
                        <span class="inline-flex items-center rounded-full bg-white px-2 py-0.5 ring-1 ring-gray-200">
                          <svg class="h-3 w-3 mr-1 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                          </svg>
                          <%= item.speaker %>
                        </span>
                      <% } %>
                      <% const highlightTs = Number(item.timestamp_seconds); if (!Number.isNaN(highlightTs)) { %>
                        <button
                          type="button"
                          class="inline-flex items-center rounded-full bg-indigo-50 px-2 py-0.5 text-indigo-700 ring-1 ring-indigo-200 hover:bg-indigo-100 cursor-pointer transition-colors"
                          onclick="jumpToTimestamp(<%= Math.floor(highlightTs) %>)"
                        >
                          <svg class="h-3 w-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                          </svg>
                          <%= Math.floor(highlightTs / 60) %>:<%= String(Math.floor(highlightTs % 60)).padStart(2, '0') %>
                        </button>
                      <% } %>
                      <% if (item.category) { %>
                        <span class="inline-flex items-center rounded-full bg-purple-50 px-2 py-0.5 text-purple-700 ring-1 ring-purple-200 capitalize"><%= item.category %></span>
                      <% } %>
                      <% if (item.impact) { %>
                        <span class="inline-flex items-center rounded-full bg-amber-50 px-2 py-0.5 text-amber-700 ring-1 ring-amber-200 capitalize">Impact: <%= item.impact %></span>
                      <% } %>
                    </div>
                  </div>
                  <span class="text-xs text-gray-400 ml-2">#<%= idx + 1 %></span>
                </div>
              </li>
            <% }); %>
          </ul>
        <% } else { %>
          <div class="text-center py-8">
            <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
            <h3 class="mt-2 text-sm font-semibold text-gray-900">No highlights yet</h3>
            <p class="mt-1 text-sm text-gray-500">Highlights will appear here after processing.</p>
          </div>
        <% } %>
      <% } %>
    </div>

    <!-- Actions Tab -->
    <div id="content-actions" class="tab-content hidden" role="tabpanel" aria-labelledby="tab-actions">
      <% if (!meeting.superAgentAnalysis || meeting.superAgentAnalysis.status !== 'completed') { %>
        <div class="text-center py-8">
          <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path>
          </svg>
          <h3 class="mt-2 text-sm font-semibold text-gray-900">Premium action items not ready</h3>
          <p class="mt-1 text-sm text-gray-500">Run Super Agent to generate timestamped actions.</p>
          <% if (meeting.artifactId) { %>
            <button
              type="button"
              onclick="openSuperAgentPanel()"
              class="mt-4 inline-flex items-center rounded-md bg-amber-500 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-amber-400"
            >
              Analyse with Super Agent
            </button>
          <% } %>
        </div>
      <% } else { %>
        <% const premiumActions = meeting.superAgentAnalysis?.actionItems || []; %>
        <% if (premiumActions.length > 0) { %>
          <%- include('action-columns', { actions: premiumActions }) -%>
        <% } else { %>
          <div class="text-center py-8">
            <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path>
            </svg>
            <h3 class="mt-2 text-sm font-semibold text-gray-900">No action items</h3>
            <p class="mt-1 text-sm text-gray-500">Action items will appear here after processing.</p>
          </div>
        <% } %>
      <% } %>
    </div>

    <!-- Transcript Tab - Lazy Loaded (shared) -->
    <%- include('tab-transcript-shared', { meeting }) -%>

    <!-- Stats Tab (shared) -->
    <%- include('tab-stats-shared', { meeting }) -%>

    <!-- Media Tab (shared) -->
    <%- include('tab-media-shared', { meeting }) -%>

    <!-- Quick Actions Tab -->
    <div id="content-quickactions" class="tab-content hidden" role="tabpanel" aria-labelledby="tab-quickactions">
      <%- include('tab-quickactions', { meeting }) -%>
    </div>
  </div>
</div>
