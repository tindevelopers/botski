<div id="content-media" class="tab-content hidden" role="tabpanel" aria-labelledby="tab-media">
  <% if (meeting.videoUrl || meeting.audioUrl || meeting.teamsRecordingUrl) { %>
    <%- include('recording', { meeting: meeting }) -%>
  <% } else { %>
    <div class="text-center py-12">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
      </svg>
      <h3 class="mt-2 text-sm font-semibold text-gray-900">No media yet</h3>
      <p class="mt-1 text-sm text-gray-500">Video or audio will appear here once the recording is available.</p>
    </div>
  <% } %>
</div>
