<div id="content-stats" class="tab-content hidden" role="tabpanel" aria-labelledby="tab-stats">
  <% const stats = meeting.stats; %>
  <div class="space-y-6">
    <!-- Sentiment and Outcome Section -->
    <%
      const statsSentimentLabel = meeting.sentiment
        ? (typeof meeting.sentiment === 'string' ? meeting.sentiment : (meeting.sentiment.label || meeting.sentiment.sentiment || null))
        : null;
      const statsSentimentData = meeting.sentimentData || (typeof meeting.sentiment === 'object' ? meeting.sentiment : null);
      const statsSentimentScore = statsSentimentData ? (statsSentimentData.score || statsSentimentData.confidence || null) : null;
    %>
    <% if (statsSentimentLabel || meeting.outcome) { %>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
        <% if (statsSentimentLabel) { %>
          <div class="rounded-lg border border-gray-100 bg-gray-50 p-4">
            <div class="flex items-center gap-3 mb-3">
              <div class="h-10 w-10 flex-shrink-0 rounded-full bg-blue-100 text-blue-700 flex items-center justify-center">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-gray-900">Sentiment Analysis</p>
                <p class="text-xs text-gray-500">Overall meeting tone</p>
              </div>
            </div>
            <%
              const statsScMap = {
                positive: { bg: 'bg-green-100', text: 'text-green-800', bar: 'bg-green-500' },
                negative: { bg: 'bg-red-100', text: 'text-red-800', bar: 'bg-red-500' },
                neutral: { bg: 'bg-gray-100', text: 'text-gray-800', bar: 'bg-gray-500' },
                mixed: { bg: 'bg-yellow-100', text: 'text-yellow-800', bar: 'bg-yellow-500' },
              };
              const statsScColors = statsScMap[statsSentimentLabel] || statsScMap.neutral;
            %>
            <div class="flex items-center gap-3">
              <span class="inline-flex items-center rounded-full <%= statsScColors.bg %> px-3 py-1 text-sm font-semibold <%= statsScColors.text %> capitalize">
                <%= statsSentimentLabel %>
              </span>
              <% if (statsSentimentScore !== null && !isNaN(Number(statsSentimentScore))) { %>
                <div class="flex-1">
                  <div class="flex items-center justify-between text-xs text-gray-500 mb-1">
                    <span>Confidence</span>
                    <span><%= (Number(statsSentimentScore) * 100).toFixed(0) %>%</span>
                  </div>
                  <div class="w-full bg-gray-200 rounded-full h-2 overflow-hidden">
                    <div class="h-2 rounded-full <%= statsScColors.bar %>" style="width:<%= Math.max(0, Math.min(100, Number(statsSentimentScore) * 100)) %>%"></div>
                  </div>
                </div>
              <% } %>
            </div>
          </div>
        <% } %>

        <% if (meeting.outcome) { %>
          <div class="rounded-lg border border-gray-100 bg-gray-50 p-4">
            <div class="flex items-center gap-3 mb-3">
              <div class="h-10 w-10 flex-shrink-0 rounded-full bg-purple-100 text-purple-700 flex items-center justify-center">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-gray-900">Meeting Outcome</p>
                <p class="text-xs text-gray-500">Overall assessment</p>
              </div>
            </div>
            <%
              const outcomeStyleMap = {
                productive: { bg: 'bg-green-100', text: 'text-green-800' },
                inconclusive: { bg: 'bg-yellow-100', text: 'text-yellow-800' },
                informational: { bg: 'bg-blue-100', text: 'text-blue-800' },
                'action-oriented': { bg: 'bg-orange-100', text: 'text-orange-800' },
              };
              const outcomeStyle = outcomeStyleMap[meeting.outcome] || { bg: 'bg-gray-100', text: 'text-gray-800' };
            %>
            <span class="inline-flex items-center rounded-full <%= outcomeStyle.bg %> px-3 py-1 text-sm font-semibold <%= outcomeStyle.text %> capitalize">
              <%= meeting.outcome %>
            </span>
          </div>
        <% } %>
      </div>
    <% } %>

    <!-- Duration and Speaker Stats -->
    <% if (stats && ((stats.speakers && stats.speakers.length) || stats.durationSeconds)) { %>
      <div class="space-y-4">
        <% if (stats.durationSeconds) { %>
          <div class="rounded-lg border border-gray-100 bg-gray-50 p-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
            <div class="flex items-center gap-3">
              <div class="h-10 w-10 flex-shrink-0 rounded-full bg-indigo-100 text-indigo-700 flex items-center justify-center font-semibold">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <div class="min-w-0">
                <p class="text-sm font-semibold text-gray-900">Estimated duration</p>
                <p class="text-sm text-gray-600">
                  <% const totalMins = Math.round(stats.durationSeconds / 60); const hours = Math.floor(totalMins / 60); const mins = totalMins % 60; %>
                  <%= hours > 0 ? `${hours}h ${mins}m` : `${mins} min` %> (<%= Math.round(stats.durationSeconds) %>s)
                </p>
              </div>
            </div>
            <% if (stats.note) { %>
              <span class="text-xs text-gray-400 sm:text-right"><%= stats.note %></span>
            <% } %>
          </div>
        <% } %>

        <% if (stats.speakers && stats.speakers.length > 0) { %>
          <div>
            <h4 class="text-sm font-semibold text-gray-900 mb-3">Talk time by speaker</h4>
            <div class="space-y-2">
              <% stats.speakers.forEach(function(speaker) { %>
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 rounded-lg border border-gray-100 p-3">
                  <div class="min-w-0 flex-1">
                    <p class="text-sm font-medium text-gray-900 truncate"><%= speaker.name || 'Speaker' %></p>
                    <p class="text-xs text-gray-500">
                      <% const secs = Math.round(speaker.talkTimeSeconds || 0); const mins = Math.floor(secs / 60); const rem = secs % 60; %>
                      <%= mins > 0 ? `${mins}m ${rem}s` : `${secs}s` %>
                      <% if (speaker.turns) { %>
                        · <%= speaker.turns %> turns
                      <% } %>
                      <% if (speaker.wordCount) { %>
                        · <%= speaker.wordCount %> words
                      <% } %>
                    </p>
                  </div>
                  <div class="flex items-center gap-3 flex-shrink-0">
                    <% if (speaker.talkTimePercent !== null && speaker.talkTimePercent !== undefined) { %>
                      <span class="text-sm font-semibold text-indigo-700 w-12 text-right"><%= speaker.talkTimePercent.toFixed(1) %>%</span>
                    <% } %>
                    <div class="w-24 sm:w-32 bg-gray-100 rounded-full h-2 overflow-hidden">
                      <% const pct = Math.max(0, Math.min(100, speaker.talkTimePercent || 0)); %>
                      <div class="h-2 bg-indigo-500" style="width:<%= pct %>%"></div>
                    </div>
                  </div>
                </div>
              <% }); %>
            </div>
          </div>
        <% } %>
      </div>
    <% } else if (!statsSentimentLabel && !meeting.outcome) { %>
      <div class="text-center py-8">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"></path>
        </svg>
        <h3 class="mt-2 text-sm font-semibold text-gray-900">Stats unavailable</h3>
        <p class="mt-1 text-sm text-gray-500">Talk-time stats will appear here once transcript timing is processed.</p>
      </div>
    <% } %>
  </div>
</div>
