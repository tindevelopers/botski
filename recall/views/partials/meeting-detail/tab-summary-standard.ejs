<div class="space-y-6">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div class="flex flex-wrap gap-2">
      <% if (meeting.artifactId && !meeting.hasBeenEnriched) { %>
        <button
          type="button"
          onclick="triggerEnrichment('<%= meeting.artifactId %>', this)"
          class="inline-flex items-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2"
        >
          <svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
          <span data-enrich-text>Generate Summary</span>
        </button>
      <% } else if (meeting.artifactId && meeting.hasBeenEnriched) { %>
        <button
          type="button"
          onclick="triggerEnrichment('<%= meeting.artifactId %>', this)"
          class="inline-flex items-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50"
        >
          <svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
          </svg>
          <span data-enrich-text>Re-generate Summary</span>
        </button>
      <% } %>
      <% if (meeting.artifactId) { %>
        <button
          type="button"
          onclick="openNotionDestinationPicker('<%= meeting.artifactId %>')"
          class="inline-flex items-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-indigo-600 shadow-sm ring-1 ring-inset ring-indigo-200 hover:bg-indigo-50"
        >
          Publish to Notion
        </button>
        <button
          type="button"
          onclick="openSlackDestinationPicker('<%= meeting.artifactId %>')"
          class="inline-flex items-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-sky-600 shadow-sm ring-1 ring-inset ring-sky-200 hover:bg-sky-50"
        >
          Publish to Slack
        </button>
      <% } %>
      <button
        type="button"
        onclick="scrollToShareSection()"
        class="inline-flex items-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50"
      >
        Share meeting
      </button>
    </div>
    <button
      type="button"
      onclick="openActionsDrawer()"
      class="lg:hidden inline-flex items-center rounded-md bg-gray-900 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-gray-900 focus:ring-offset-2"
    >
      Actions
    </button>
  </div>

  <%- include('upgrade-banner') -%>

  <!-- Metadata badges: Source, Sentiment, Outcome -->
  <div class="flex flex-wrap items-center gap-2">
    <% if (meeting.summarySource) { %>
      <span class="inline-flex items-center rounded-full bg-indigo-50 px-2.5 py-0.5 text-xs font-medium text-indigo-700 ring-1 ring-inset ring-indigo-200">
        Source: <%= meeting.summarySource === 'recall_webhook' ? 'Recall' : meeting.summarySource === 'openai' ? 'OpenAI' : meeting.summarySource === 'anthropic' ? 'Anthropic' : meeting.summarySource === 'assemblyai' ? 'Super Agent' : meeting.summarySource %>
      </span>
    <% } else { %>
      <span class="inline-flex items-center rounded-full bg-indigo-50 px-2.5 py-0.5 text-xs font-medium text-indigo-700 ring-1 ring-inset ring-indigo-200">
        Source: Recall/OpenAI
      </span>
    <% } %>
    <%
      const sentimentLabel = meeting.sentiment
        ? (typeof meeting.sentiment === 'string' ? meeting.sentiment : (meeting.sentiment.label || meeting.sentiment.sentiment || 'neutral'))
        : null;
      const sentimentColors = {
        positive: { bg: 'bg-green-50', text: 'text-green-700', ring: 'ring-green-200' },
        negative: { bg: 'bg-red-50', text: 'text-red-700', ring: 'ring-red-200' },
        neutral: { bg: 'bg-gray-50', text: 'text-gray-700', ring: 'ring-gray-200' },
        mixed: { bg: 'bg-yellow-50', text: 'text-yellow-700', ring: 'ring-yellow-200' },
      };
      const sc = sentimentColors[sentimentLabel] || sentimentColors.neutral;
    %>
    <% if (sentimentLabel) { %>
      <span class="inline-flex items-center rounded-full <%= sc.bg %> px-2.5 py-0.5 text-xs font-medium <%= sc.text %> ring-1 ring-inset <%= sc.ring %> capitalize">
        <svg class="mr-1 h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        Sentiment: <%= sentimentLabel %>
      </span>
    <% } %>
    <% if (meeting.outcome) { %>
      <%
        const outcomeColors = {
          productive: { bg: 'bg-green-50', text: 'text-green-700', ring: 'ring-green-200' },
          inconclusive: { bg: 'bg-yellow-50', text: 'text-yellow-700', ring: 'ring-yellow-200' },
          informational: { bg: 'bg-blue-50', text: 'text-blue-700', ring: 'ring-blue-200' },
          'action-oriented': { bg: 'bg-orange-50', text: 'text-orange-700', ring: 'ring-orange-200' },
        };
        const oc = outcomeColors[meeting.outcome] || { bg: 'bg-gray-50', text: 'text-gray-700', ring: 'ring-gray-200' };
      %>
      <span class="inline-flex items-center rounded-full <%= oc.bg %> px-2.5 py-0.5 text-xs font-medium <%= oc.text %> ring-1 ring-inset <%= oc.ring %> capitalize">
        <svg class="mr-1 h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        Outcome: <%= meeting.outcome %>
      </span>
    <% } %>
  </div>

  <div class="grid grid-cols-1 gap-6 lg:grid-cols-12">
    <div class="lg:col-span-7 space-y-6">
      <!-- Summary Card -->
      <div class="overflow-hidden bg-white shadow sm:rounded-lg">
        <div class="px-4 py-5 sm:px-6 border-b border-gray-200 flex items-center justify-between">
          <h2 class="text-base font-semibold text-gray-900">Summary</h2>
        </div>
        <div class="px-4 py-5 sm:px-6">
          <% if (meeting.summary) { %>
            <div class="prose prose-sm max-w-none text-gray-700">
              <%= meeting.summary %>
            </div>
          <% } else { %>
            <div class="text-center py-6">
              <svg class="mx-auto h-10 w-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
              </svg>
              <h3 class="mt-2 text-sm font-semibold text-gray-900">No summary available</h3>
              <p class="mt-1 text-sm text-gray-500">An AI-generated summary will appear here once the meeting is processed.</p>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Key Insights -->
      <% if (meeting.keyInsights && meeting.keyInsights.length > 0) { %>
        <div class="overflow-hidden bg-white shadow sm:rounded-lg">
          <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
            <h2 class="text-base font-semibold text-gray-900 flex items-center">
              <svg class="w-4 h-4 mr-2 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
              </svg>
              Key Insights
            </h2>
          </div>
          <div class="px-4 py-5 sm:px-6">
            <ul class="space-y-3">
              <% meeting.keyInsights.forEach(function(insight) { %>
                <li class="flex items-start">
                  <span class="flex-shrink-0 h-5 w-5 flex items-center justify-center rounded-full bg-yellow-100 text-yellow-600 text-xs font-bold mt-0.5">&#x1F4A1;</span>
                  <span class="ml-2 text-sm text-gray-700">
                    <% if (typeof insight === 'object') { %>
                      <%= insight.text || insight.insight || insight.description || JSON.stringify(insight) %>
                    <% } else { %>
                      <%= insight %>
                    <% } %>
                  </span>
                </li>
              <% }); %>
            </ul>
          </div>
        </div>
      <% } %>

      <!-- Decisions Made -->
      <% if (meeting.decisions && meeting.decisions.length > 0) { %>
        <div class="overflow-hidden bg-white shadow sm:rounded-lg">
          <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
            <h2 class="text-base font-semibold text-gray-900 flex items-center">
              <svg class="w-4 h-4 mr-2 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              Decisions Made
            </h2>
          </div>
          <div class="px-4 py-5 sm:px-6">
            <ul class="space-y-2">
              <% meeting.decisions.forEach(function(decision) { %>
                <li class="flex items-start bg-purple-50 rounded-lg p-2">
                  <svg class="h-4 w-4 text-purple-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                  <span class="ml-2 text-sm text-gray-700">
                    <% if (typeof decision === 'object') { %>
                      <%= decision.text || decision.decision || decision.description || JSON.stringify(decision) %>
                    <% } else { %>
                      <%= decision %>
                    <% } %>
                  </span>
                </li>
              <% }); %>
            </ul>
          </div>
        </div>
      <% } %>

      <!-- Topics Preview -->
      <% if (meeting.topics && meeting.topics.length > 0) { %>
        <div class="overflow-hidden bg-white shadow sm:rounded-lg">
          <div class="px-4 py-5 sm:px-6 border-b border-gray-200 flex items-center justify-between">
            <h2 class="text-base font-semibold text-gray-900 flex items-center">
              <svg class="w-4 h-4 mr-2 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h10"></path>
              </svg>
              Topics
            </h2>
            <button type="button" onclick="switchTab('topics')" class="text-xs font-medium text-indigo-600 hover:text-indigo-800">
              View all (<%= meeting.topics.length %>)
            </button>
          </div>
          <div class="px-4 py-5 sm:px-6">
            <ul class="space-y-2">
              <% meeting.topics.slice(0, 3).forEach(function(topic, idx) { %>
                <li class="flex items-start">
                  <span class="mt-1 h-2 w-2 rounded-full bg-indigo-400 flex-shrink-0"></span>
                  <span class="ml-2 text-sm text-gray-700">
                    <% if (typeof topic === 'string') { %>
                      <%= topic %>
                    <% } else if (topic.title || topic.name || topic.topic || topic.heading) { %>
                      <%= topic.title || topic.name || topic.topic || topic.heading %>
                    <% } else { %>
                      Topic <%= idx + 1 %>
                    <% } %>
                  </span>
                </li>
              <% }); %>
            </ul>
          </div>
        </div>
      <% } %>

      <!-- Highlights Preview -->
      <% if (meeting.highlights && meeting.highlights.length > 0) { %>
        <div class="overflow-hidden bg-white shadow sm:rounded-lg">
          <div class="px-4 py-5 sm:px-6 border-b border-gray-200 flex items-center justify-between">
            <h2 class="text-base font-semibold text-gray-900 flex items-center">
              <svg class="w-4 h-4 mr-2 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
              Highlights
            </h2>
            <button type="button" onclick="switchTab('highlights')" class="text-xs font-medium text-indigo-600 hover:text-indigo-800">
              View all (<%= meeting.highlights.length %>)
            </button>
          </div>
          <div class="px-4 py-5 sm:px-6">
            <ul class="space-y-2">
              <% meeting.highlights.slice(0, 2).forEach(function(item, idx) { %>
                <li class="p-2 rounded-lg border border-gray-100 bg-gray-50">
                  <p class="text-sm font-medium text-gray-900"><%= item.title || 'Highlight ' + (idx + 1) %></p>
                  <p class="mt-0.5 text-sm text-gray-600"><%= item.content || item.summary || item.text || '' %></p>
                </li>
              <% }); %>
            </ul>
          </div>
        </div>
      <% } %>

      <!-- Detailed Notes Preview -->
      <% if (meeting.detailedNotes && meeting.detailedNotes.length > 0) { %>
        <div class="overflow-hidden bg-white shadow sm:rounded-lg">
          <div class="px-4 py-5 sm:px-6 border-b border-gray-200 flex items-center justify-between">
            <h2 class="text-base font-semibold text-gray-900 flex items-center">
              <svg class="w-4 h-4 mr-2 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-4 4v-4z"></path>
              </svg>
              Detailed Notes
            </h2>
            <button type="button" onclick="switchTab('detailed')" class="text-xs font-medium text-indigo-600 hover:text-indigo-800">
              View all (<%= meeting.detailedNotes.length %>)
            </button>
          </div>
          <div class="px-4 py-5 sm:px-6">
            <ul class="space-y-2">
              <% meeting.detailedNotes.slice(0, 2).forEach(function(item) { %>
                <li class="p-2 rounded-lg border border-gray-100 bg-white">
                  <div class="flex items-center gap-2 text-xs text-gray-500 mb-1">
                    <% if (item.speaker) { %>
                      <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-gray-700"><%= item.speaker %></span>
                    <% } %>
                    <% if (item.topic) { %>
                      <span class="inline-flex items-center rounded-full bg-blue-50 px-2 py-0.5 text-blue-700"><%= item.topic %></span>
                    <% } %>
                  </div>
                  <p class="text-sm text-gray-800"><%= item.paraphrase || item.content || item.note || item.summary || item.text || '' %></p>
                </li>
              <% }); %>
            </ul>
          </div>
        </div>
      <% } %>

      <!-- Action Items and Follow-ups side by side -->
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        <div class="overflow-hidden bg-white shadow sm:rounded-lg">
          <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
            <h2 class="text-base font-semibold text-gray-900">Action Items</h2>
          </div>
          <div class="px-4 py-5 sm:px-6">
            <% const actionItems = meeting.actionItems || []; %>
            <% if (actionItems.length > 0) { %>
              <ul class="space-y-2">
                <% actionItems.slice(0, 3).forEach(function(item) { %>
                  <li class="flex items-start">
                    <span class="mt-1 h-2.5 w-2.5 rounded-full bg-orange-400 flex-shrink-0"></span>
                    <span class="ml-2 text-sm text-gray-700">
                      <% if (typeof item === 'object') { %>
                        <%= item.text || item.action || item.description || JSON.stringify(item) %>
                      <% } else { %>
                        <%= item %>
                      <% } %>
                    </span>
                  </li>
                <% }); %>
              </ul>
              <% if (actionItems.length > 3) { %>
                <button type="button" onclick="switchTab('actions')" class="mt-3 text-xs font-medium text-indigo-600 hover:text-indigo-800">
                  View all actions (<%= actionItems.length %>)
                </button>
              <% } %>
            <% } else { %>
              <p class="text-sm text-gray-500">No action items yet.</p>
            <% } %>
          </div>
        </div>

        <div class="overflow-hidden bg-white shadow sm:rounded-lg">
          <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
            <h2 class="text-base font-semibold text-gray-900">Follow-ups</h2>
          </div>
          <div class="px-4 py-5 sm:px-6">
            <% const followUps = meeting.followUps || []; %>
            <% if (followUps.length > 0) { %>
              <ul class="space-y-2">
                <% followUps.slice(0, 3).forEach(function(item) { %>
                  <li class="flex items-start">
                    <span class="mt-1 h-2.5 w-2.5 rounded-full bg-blue-400 flex-shrink-0"></span>
                    <span class="ml-2 text-sm text-gray-700">
                      <% if (typeof item === 'object') { %>
                        <%= item.text || item.followUp || item.description || JSON.stringify(item) %>
                      <% } else { %>
                        <%= item %>
                      <% } %>
                    </span>
                  </li>
                <% }); %>
              </ul>
              <% if (followUps.length > 3) { %>
                <button type="button" onclick="switchTab('followups')" class="mt-3 text-xs font-medium text-indigo-600 hover:text-indigo-800">
                  View all follow-ups (<%= followUps.length %>)
                </button>
              <% } %>
            <% } else { %>
              <p class="text-sm text-gray-500">No follow-ups yet.</p>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Stats Summary Card -->
      <% const statsData = meeting.stats; %>
      <% if (statsData && (statsData.durationSeconds || (statsData.speakers && statsData.speakers.length > 0))) { %>
        <div class="overflow-hidden bg-white shadow sm:rounded-lg">
          <div class="px-4 py-5 sm:px-6 border-b border-gray-200 flex items-center justify-between">
            <h2 class="text-base font-semibold text-gray-900 flex items-center">
              <svg class="w-4 h-4 mr-2 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"></path>
              </svg>
              Meeting Stats
            </h2>
            <button type="button" onclick="switchTab('stats')" class="text-xs font-medium text-indigo-600 hover:text-indigo-800">
              View details
            </button>
          </div>
          <div class="px-4 py-5 sm:px-6">
            <div class="flex flex-wrap gap-4">
              <% if (statsData.durationSeconds) { %>
                <div class="flex items-center gap-2">
                  <div class="h-8 w-8 rounded-full bg-indigo-100 text-indigo-700 flex items-center justify-center">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                  </div>
                  <div>
                    <p class="text-xs text-gray-500">Duration</p>
                    <% const totalMins = Math.round(statsData.durationSeconds / 60); const hours = Math.floor(totalMins / 60); const mins = totalMins % 60; %>
                    <p class="text-sm font-semibold text-gray-900"><%= hours > 0 ? `${hours}h ${mins}m` : `${mins} min` %></p>
                  </div>
                </div>
              <% } %>
              <% if (statsData.speakers && statsData.speakers.length > 0) { %>
                <div class="flex items-center gap-2">
                  <div class="h-8 w-8 rounded-full bg-purple-100 text-purple-700 flex items-center justify-center">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"></path>
                    </svg>
                  </div>
                  <div>
                    <p class="text-xs text-gray-500">Speakers</p>
                    <p class="text-sm font-semibold text-gray-900"><%= statsData.speakers.length %></p>
                  </div>
                </div>
              <% } %>
            </div>
          </div>
        </div>
      <% } %>
    </div>

    <div class="lg:col-span-5 space-y-6">
      <%- include('tab-snapshot', { meeting }) -%>
    </div>
  </div>

  <div id="share-meeting-section" class="space-y-6">
    <% if (meeting.isOwner) { %>
      <div class="overflow-hidden bg-white shadow sm:rounded-lg">
        <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
          <h2 class="text-base font-semibold text-gray-900 flex items-center">
            <svg class="w-4 h-4 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"></path>
            </svg>
            Share Meeting
          </h2>
        </div>
        <div class="px-4 py-5 sm:px-6">
          <p class="text-sm text-gray-500 mb-4">Share this meeting's transcript and summary with attendees.</p>
          <div id="share-attendees-container">
            <div class="mb-4">
              <label for="share-email" class="block text-sm font-medium text-gray-700 mb-1">Share with email</label>
              <div class="flex gap-2">
                <input
                  type="email"
                  id="share-email"
                  placeholder="email@example.com"
                  class="flex-1 rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm"
                >
                <button
                  type="button"
                  onclick="shareMeeting()"
                  class="inline-flex items-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-500"
                >
                  Share
                </button>
              </div>
            </div>
            <div id="attendees-to-share" class="space-y-2">
              <p class="text-xs text-gray-500">Loading attendees...</p>
            </div>
          </div>
          <div id="current-shares" class="mt-4 pt-4 border-t border-gray-200">
            <h3 class="text-sm font-medium text-gray-700 mb-2">Shared with</h3>
            <div id="shares-list" class="space-y-2">
              <p class="text-xs text-gray-500">Loading...</p>
            </div>
          </div>
        </div>
      </div>
    <% } else if (meeting.isShared) { %>
      <div class="overflow-hidden bg-white shadow sm:rounded-lg">
        <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
          <h2 class="text-base font-semibold text-gray-900 flex items-center">
            <svg class="w-4 h-4 mr-2 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"></path>
            </svg>
            Shared Meeting
          </h2>
        </div>
        <div class="px-4 py-5 sm:px-6">
          <div class="flex items-center text-sm text-gray-600">
            <svg class="w-4 h-4 mr-2 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span>
              Shared by <strong><%= meeting.shareInfo?.sharedBy?.name || meeting.shareInfo?.sharedBy?.email || 'Unknown' %></strong>
            </span>
          </div>
          <p class="mt-2 text-xs text-gray-500">
            Access level: <span class="capitalize"><%= meeting.shareInfo?.accessLevel || 'view' %></span>
          </p>
        </div>
      </div>
    <% } %>
  </div>
</div>
